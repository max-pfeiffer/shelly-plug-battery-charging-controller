{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "complexity": {
        "useArrowFunction": "off"
      },
      "style": {
        "useConst": "off",
        "useTemplate": "off"
      }
    }
  }
}
